<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Smart Grama Panchayat</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <!-- Chart.js for ML Analytics -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <i class="fas fa-landmark"></i>
          <span>Panchayat Admin</span>
        </div>
      </div>
            <ul class="sidebar-menu">
        <li><a href="/admin-dashboard" class="active"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li><a href="/admin-properties"><i class="fas fa-city"></i> Properties</a></li>
        <li><a href="/admin-citizens"><i class="fas fa-users"></i> Citizens</a></li>
        <li><a href="/admin-tax"><i class="fas fa-receipt"></i> Tax Management</a></li>
        <li><a href="/admin-reminders"><i class="fas fa-bell"></i> SMS Reminders</a></li>
        
        <li><a href="/admin-complaints"><i class="fas fa-exclamation-triangle"></i> Complaints</a></li>
        <li><a href="/admin-services"><i class="fas fa-cogs"></i> Services</a></li>
        <li><a href="/admin-schemes"><i class="fas fa-hand-holding-usd"></i> Schemes</a></li>
        <li><a href="/admin-ml-performance"><i class="fas fa-chart-line"></i> ML Performance</a></li>
        <li><a href="/admin-logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
      <div class="admin-header">
        <div>
          <h1>Dashboard Overview</h1>
          <p class="text-muted">Smart Governance Analytics & AI Portal</p>
        </div>
        <div class="d-flex gap-2">
          <button id="retrainBtn" class="btn btn-primary">
            <i class="fas fa-sync-alt"></i> Export & Retrain ML Models
          </button>
          <a href="/" class="btn btn-outline" target="_blank">
            <i class="fas fa-external-link-alt"></i> View Site
          </a>
        </div>
      </div>

      <!-- Retraining Progress Overlay -->
      <div id="retrainProgressCard" class="card mb-4 hidden" style="border-left: 4px solid var(--accent);">
        <div class="card-header">
          <h3 class="card-title" id="retrainStatusText"><i class="fas fa-spinner fa-spin"></i> Exporting Data & Retraining Models...</h3>
        </div>
        <div class="card-body">
          <pre id="retrainLogArea" style="background: #212121; color: #4CAF50; padding: 15px; border-radius: var(--radius-sm); font-family: monospace; max-height: 150px; overflow-y: auto; font-size: 0.85rem; margin-top: 10px;">Initializing retraining logs...</pre>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        <div class="stat-card">
          <div class="stat-icon green">
            <i class="fas fa-rupee-sign"></i>
          </div>
          <div class="stat-info">
            <h3>₹<%= (stats.collection || 0).toLocaleString('en-IN') %></h3>
            <p>Total Tax Collected</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon orange">
            <i class="fas fa-clock"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.pending || 0) %></h3>
            <p>Pending Tax Records</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon blue">
            <i class="fas fa-home"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.properties || 0) %></h3>
            <p>Total Properties</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon yellow" style="background:#FFF9C4; color:#F57F17; border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-users"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.citizens || 0) %></h3>
            <p>Total Citizens</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon teal" style="background:#E0F2F1; color:#00796B; border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-calendar-check"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.todayAppointments || 0) %></h3>
            <p>Today's Appointments</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon red" style="background:#FFEBEE; color:#C62828; border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-exclamation-circle"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.totalComplaints || 0) %></h3>
            <p>Total Complaints</p>
          </div>
        </div>

        <div class="stat-card" style="border: 1px solid #FFCDD2; background: #FFF5F5;">
          <div class="stat-icon error" style="border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-fire"></i>
          </div>
          <div class="stat-info">
            <h3 style="color:#C62828;"><%= (stats.highPriorityComplaints || 0) %></h3>
            <p style="font-weight:600; color:#B71C1C;">High Priority</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon purple" style="background:#F3E5F5; color:#7B1FA2; border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-hand-holding-heart"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.activeSchemes || 0) %></h3>
            <p>Active Schemes</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon teal" style="background:#E0F7FA; color:#00838F; border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-cogs"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.activeServices || 0) %></h3>
            <p>Active Services</p>
          </div>
        </div>
      </div>

      <!-- ML Metadata & Smart Alerts Panel -->
      <div class="grid-2 mt-4">
        <!-- ML Info -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-brain"></i> Active Machine Learning Models</h3>
            <span class="status-badge active">Version <%= mlMeta.version %></span>
          </div>
          <div class="card-body">
            <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 10px;">
              <div class="d-flex justify-between" style="border-bottom: 1px solid #EEE; padding-bottom: 8px;">
                <span class="text-muted"><i class="fas fa-calendar-check"></i> Last Retrained:</span>
                <strong><%= mlMeta.last_trained %></strong>
              </div>
              <div class="d-flex justify-between" style="border-bottom: 1px solid #EEE; padding-bottom: 8px;">
                <span class="text-muted"><i class="fas fa-database"></i> Training Set Size:</span>
                <strong><%= mlMeta.dataset_size %> samples</strong>
              </div>
              <div class="d-flex justify-between" style="border-bottom: 1px solid #EEE; padding-bottom: 8px;">
                <span class="text-muted"><i class="fas fa-folder-open"></i> Excel Datasets Path:</span>
                <span style="font-family: monospace; font-size: 0.85rem; color: var(--secondary);">/datasets/*.xlsx</span>
              </div>
              <a href="/admin-ml-performance" class="btn btn-outline btn-sm mt-3" style="width: 100%; justify-content: center;">
                <i class="fas fa-chart-bar"></i> View Detailed Performance Metrics
              </a>
            </div>
          </div>
        </div>

        <!-- Smart Alerts -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-bell"></i> AI Smart Notifications & Alerts</h3>
            <span class="status-badge <%= alerts.length > 0 ? 'unpaid' : 'paid' %>"><%= alerts.length %> New</span>
          </div>
          <div class="card-body" style="max-height: 250px; overflow-y: auto;">
            <% if (alerts && alerts.length > 0) { %>
              <div style="display: flex; flex-direction: column; gap: 10px;">
                <% alerts.forEach(function(alert) { %>
                  <div class="alert-item" data-id="<%= alert.id %>" style="padding: 10px; border-radius: var(--radius-sm); background: #F5F5F5; border-left: 4px solid <%= alert.type === 'Alert' ? 'var(--error)' : alert.type === 'Duplicate' ? 'var(--warning)' : 'var(--secondary)' %>; position: relative;">
                    <div class="d-flex justify-between align-items-center" style="margin-bottom: 4px;">
                      <strong style="font-size: 0.9rem;"><%= alert.title %></strong>
                      <small class="text-muted"><%= new Date(alert.created_at).toLocaleTimeString('en-IN') %></small>
                    </div>
                    <p style="font-size: 0.85rem; margin: 0; color: var(--text-secondary);"><%= alert.message %></p>
                    <button class="dismiss-alert-btn" style="position: absolute; top: 5px; right: 5px; background: none; border: none; cursor: pointer; color: #BBB;">&times;</button>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="text-center text-muted py-4">
                <i class="fas fa-check-circle fa-2x mb-2" style="color: var(--success);"></i>
                <p>No active alerts. Panchayat operating smoothly!</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Chart.js Visualizations Section -->
      <div class="card mt-4">
        <div class="card-header">
          <h3 class="card-title"><i class="fas fa-chart-pie"></i> ML Insights & Predictive Analytics</h3>
        </div>
        <div class="card-body">
          <div class="grid-3" style="margin-top: 15px;">
            <!-- Priority Chart -->
            <div style="text-align: center;">
              <h4 style="margin-bottom: 10px; font-size: 0.95rem;">Complaint Priorities (ML)</h4>
              <div style="width: 220px; height: 220px; margin: 0 auto;">
                <canvas id="priorityChart"></canvas>
              </div>
            </div>

            <!-- Category Chart -->
            <div style="text-align: center;">
              <h4 style="margin-bottom: 10px; font-size: 0.95rem;">Complaint Categories (ML)</h4>
              <div style="width: 260px; height: 220px; margin: 0 auto;">
                <canvas id="categoryChart"></canvas>
              </div>
            </div>

            <!-- Tax Default Risk Chart -->
            <div style="text-align: center;">
              <h4 style="margin-bottom: 10px; font-size: 0.95rem;">Tax Default Risk (ML)</h4>
              <div style="width: 220px; height: 220px; margin: 0 auto;">
                <canvas id="defaultRiskChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Payments -->
      <div class="card mt-4">
        <div class="card-header">
          <h3 class="card-title">Recent Payments</h3>
          <a href="/admin-tax" class="btn btn-sm btn-outline">View All</a>
        </div>
        <div class="table-container" style="box-shadow: none;">
          <table class="table">
            <thead>
              <tr>
                <th>Transaction ID</th>
                <th>Property ID</th>
                <th>Owner Name</th>
                <th>Amount</th>
                <th>Date</th>
                <th>Method</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof recentPayments !== 'undefined' && recentPayments && recentPayments.length > 0) { %>
                <% recentPayments.forEach(function(payment) { %>
                  <tr>
                    <td><strong><%= payment.transaction_id %></strong></td>
                    <td><%= payment.property_id %></td>
                    <td><%= payment.owner_name || 'N/A' %></td>
                    <td><strong>₹<%= (payment.amount || 0).toLocaleString('en-IN') %></strong></td>
                    <td><%= new Date(payment.payment_date).toLocaleDateString('en-IN') %></td>
                    <td>Online</td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center text-muted">No recent payments</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Tax Defaulter Risk Panel -->
      <div class="card mt-4">
        <div class="card-header">
          <h3 class="card-title"><i class="fas fa-exclamation-triangle" style="color:#C62828; margin-right:6px;"></i> High Default Risk Properties (ML Analysis)</h3>
          <a href="/admin-tax" class="btn btn-sm btn-outline">Analyze All</a>
        </div>
        <div class="table-container" style="box-shadow: none; padding: 15px;">
          <table class="table" style="font-size:0.9rem;">
            <thead>
              <tr>
                <th>Property ID</th>
                <th>Owner Name</th>
                <th>Contact</th>
                <th>Unpaid Tax</th>
                <th>Year</th>
                <th>Default Probability</th>
                <th>AI Explanation</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof highRiskDefaulters !== 'undefined' && highRiskDefaulters && highRiskDefaulters.length > 0) { %>
                <% highRiskDefaulters.forEach(function(record) { %>
                  <tr>
                    <td><strong><%= record.property_id %></strong></td>
                    <td><%= record.owner_name %></td>
                    <td><%= record.phone || 'N/A' %></td>
                    <td><strong class="text-danger">₹<%= record.tax_amount.toLocaleString('en-IN') %></strong></td>
                    <td><%= record.year %></td>
                    <td>
                      <span class="status-badge overdue" style="font-weight: 600; padding: 4px 10px;">
                        <%= Math.round(record.payment_probability) %>%
                      </span>
                    </td>
                    <td style="max-width: 250px; font-size: 0.8rem; color: #555; line-height: 1.3;"><%= record.xai_explanation || 'No historical payment matches.' %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center text-muted">No high-risk tax records detected.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Offline Payment Appointments Section -->
      <div class="card mt-4">
        <div class="card-header">
          <h3 class="card-title"><i class="fas fa-calendar-check"></i> Offline Payment Appointments</h3>
        </div>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>Property ID</th>
                <th>Citizen Name</th>
                <th>Mobile</th>
                <th>Date & Time</th>
                <th>Tax Amount</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof appointments !== 'undefined' && appointments && appointments.length > 0) { %>
                <% appointments.forEach(function(app) { %>
                  <tr>
                    <td><strong><%= app.property_id %></strong></td>
                    <td><%= app.citizen_name %></td>
                    <td><%= app.phone %></td>
                    <td><%= app.appointment_date %> at <%= app.appointment_time %></td>
                    <td><strong>₹<%= app.tax_amount.toLocaleString('en-IN') %></strong></td>
                    <td><span class="status-badge active" style="font-size: 0.75rem;"><%= app.payment_type %></span></td>
                    <td>
                      <span class="status-badge <%= app.status === 'Completed' ? 'paid' : app.status === 'Rejected' ? 'overdue' : app.status === 'Approved' ? 'active' : 'unpaid' %>" style="font-size: 0.75rem;">
                        <%= app.status %>
                      </span>
                    </td>
                    <td>
                      <% if (app.status === 'Pending') { %>
                        <button onclick="updateAppointment('<%= app.id %>', 'Approved')" class="btn btn-sm btn-success" style="padding: 4px 8px; margin-right: 4px; font-size: 0.75rem; cursor: pointer;"><i class="fas fa-check"></i> Approve</button>
                        <button onclick="updateAppointment('<%= app.id %>', 'Rejected')" class="btn btn-sm btn-danger" style="padding: 4px 8px; font-size: 0.75rem; cursor: pointer;"><i class="fas fa-times"></i> Reject</button>
                      <% } else if (app.status === 'Approved') { %>
                        <button onclick="updateAppointment('<%= app.id %>', 'Completed')" class="btn btn-sm btn-primary" style="padding: 4px 8px; margin-right: 4px; font-size: 0.75rem; cursor: pointer;"><i class="fas fa-check-double"></i> Complete</button>
                        <button onclick="updateAppointment('<%= app.id %>', 'Rejected')" class="btn btn-sm btn-danger" style="padding: 4px 8px; font-size: 0.75rem; cursor: pointer;"><i class="fas fa-times"></i> Reject</button>
                      <% } else { %>
                        <span class="text-muted" style="font-size: 0.8rem;"><i class="fas fa-lock"></i> Finalized</span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="8" class="text-center text-muted">No offline payment appointments booked.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Custom Grid CSS inside head or stylesheet -->
  <style>
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
    }
    .grid-3 {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 25px;
      align-items: center;
    }
    .hidden {
      display: none !important;
    }
    .dismiss-alert-btn:hover {
      color: #333 !important;
    }
  </style>

  <script src="/js/main.js?v=<%= Date.now() %>"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      // 1. Initialise Retraining Button click
      const retrainBtn = document.getElementById("retrainBtn");
      const progressCard = document.getElementById("retrainProgressCard");
      const statusText = document.getElementById("retrainStatusText");
      const logArea = document.getElementById("retrainLogArea");

      retrainBtn.addEventListener("click", () => {
        retrainBtn.disabled = true;
        progressCard.classList.remove("hidden");
        statusText.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Exporting Data & Retraining Models...';
        logArea.innerText = "Querying latest database tables...\nExporting records to Excel datasets...\nLaunching ML retraining script...\n";

        fetch('/api/admin/retrain', {
          method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            statusText.innerHTML = '<i class="fas fa-check-circle" style="color: var(--success);"></i> Model Retraining Complete!';
            logArea.innerText += "\n[SUCCESS] Retrain Complete!\nLogs:\n" + data.logs;
            // Reload page after a delay
            setTimeout(() => window.location.reload(), 4000);
          } else {
            statusText.innerHTML = '<i class="fas fa-exclamation-triangle" style="color: var(--error);"></i> Training Failed';
            logArea.innerText += "\n[ERROR] Retraining failed:\n" + data.logs;
            retrainBtn.disabled = false;
          }
        })
        .catch(err => {
          statusText.innerHTML = '<i class="fas fa-exclamation-triangle" style="color: var(--error);"></i> Network Error';
          logArea.innerText += "\n[ERROR] Network error contacting API: " + err.message;
          retrainBtn.disabled = false;
        });
      });

      // Dismiss Alert
      document.querySelectorAll(".dismiss-alert-btn").forEach(btn => {
        btn.addEventListener("click", function() {
          const item = btn.closest(".alert-item");
          const id = item.getAttribute("data-id");
          fetch('/api/notifications/read', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              item.style.transition = 'all 0.3s ease';
              item.style.opacity = '0';
              item.style.transform = 'translateX(20px)';
              setTimeout(() => item.remove(), 300);
            }
          });
        });
      });

      // Update Appointment Status
      window.updateAppointment = function(id, status) {
        if (!confirm(`Are you sure you want to mark this appointment as ${status}?`)) return;
        fetch('/api/admin/update-appointment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('Appointment status updated successfully!');
            window.location.reload();
          } else {
            alert(data.error || 'Failed to update appointment.');
          }
        })
        .catch(err => {
          alert('Error: ' + err.message);
        });
      };

      // 2. Render Chart.js Analytics Graphs
      const chartData = <%- JSON.stringify(charts) %>;

      // Priority Distribution Chart
      const pCtx = document.getElementById('priorityChart').getContext('2d');
      new Chart(pCtx, {
        type: 'pie',
        data: {
          labels: ['High', 'Medium', 'Low'],
          datasets: [{
            data: [chartData.priorityDist.High || 0, chartData.priorityDist.Medium || 0, chartData.priorityDist.Low || 0],
            backgroundColor: ['#E53935', '#FFA000', '#43A047'],
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 10 } } }
          }
        }
      });

      // Category Distribution Chart
      const cCtx = document.getElementById('categoryChart').getContext('2d');
      const catLabels = Object.keys(chartData.catDist || {});
      const catValues = Object.values(chartData.catDist || {});
      new Chart(cCtx, {
        type: 'bar',
        data: {
          labels: catLabels.length > 0 ? catLabels : ['None'],
          datasets: [{
            label: 'Complaints',
            data: catValues.length > 0 ? catValues : [0],
            backgroundColor: '#1565C0',
            borderRadius: 5
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            y: { beginAtZero: true, ticks: { precision: 0 } }
          }
        }
      });

      // Tax Default Risk Chart
      const tCtx = document.getElementById('defaultRiskChart').getContext('2d');
      new Chart(tCtx, {
        type: 'doughnut',
        data: {
          labels: ['High Risk', 'Medium Risk', 'Low Risk'],
          datasets: [{
            data: [chartData.defaultRiskDist['High Risk'] || 0, chartData.defaultRiskDist['Medium Risk'] || 0, chartData.defaultRiskDist['Low Risk'] || 0],
            backgroundColor: ['#E53935', '#FFA000', '#1565C0'],
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 10 } } }
          }
        }
      });
    });
  </script>
</body>
</html>
