<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tax Management - Admin | Smart Grama Panchayat</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&amp;family=Open+Sans:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
</head>
<body>
  <nav class="header">
    <div class="navbar">
      <div class="logo">
        <div class="logo-icon"><i class="fas fa-landmark"></i></div>
        <div class="logo-text">Panchayat Admin</div>
      </div>
      <ul class="nav-links">
        <li><a href="/admin-dashboard" class="nav-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li><a href="/admin-tax" class="nav-link active"><i class="fas fa-receipt"></i> Tax Management</a></li>
        <li><a href="/admin-services" class="nav-link"><i class="fas fa-cogs"></i> Services</a></li>
        <li><a href="/admin-logout" class="nav-link"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
      <button class="mobile-menu-btn"><i class="fas fa-bars"></i></button>
    </div>
  </nav>

  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <i class="fas fa-shield-alt"></i> Admin
        </div>
      </div>
      <ul class="sidebar-menu">
        <li><a href="/admin-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li><a href="/admin-properties"><i class="fas fa-city"></i> Properties</a></li>
        <li><a href="/admin-citizens"><i class="fas fa-users"></i> Citizens</a></li>
        <li><a href="/admin-tax" class="active"><i class="fas fa-receipt"></i> Tax Management</a></li>
        <li><a href="/admin-reminders"><i class="fas fa-bell"></i> SMS Reminders</a></li>
        
        <li><a href="/admin-complaints"><i class="fas fa-exclamation-triangle"></i> Complaints</a></li>
        <li><a href="/admin-services"><i class="fas fa-cogs"></i> Services</a></li>
        <li><a href="/admin-schemes"><i class="fas fa-hand-holding-usd"></i> Schemes</a></li>
        <li><a href="/admin-ml-performance"><i class="fas fa-chart-line"></i> ML Performance</a></li>
        <li><a href="/admin-logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
    </aside>

    <main class="admin-content">
      <div class="container">
        <div class="admin-header">
          <h1><i class="fas fa-receipt"></i> Tax Management</h1>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon blue"><i class="fas fa-file-invoice"></i></div>
              <div class="stat-info">
                <h3><%= taxRecords ? taxRecords.length : 0 %></h3>
                <p>Total Tax Records</p>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
              <div class="stat-info">
                <h3><%= taxRecords.filter(r => r.status !== 'Paid').length %></h3>
                <p>Pending Collections</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Excel Import Panel -->
        <div class="card mb-4">
          <div class="card-header" style="background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%); color: white; display: flex; justify-content: space-between; align-items: center;">
            <h3 class="card-title" style="color: white; margin: 0;"><i class="fas fa-file-excel"></i> Import Tax Records from Excel</h3>
            <span style="font-size: 0.8rem; opacity: 0.9;">Required: property_id, tax_amount, due_date, year</span>
          </div>
          <div class="card-body" style="display: flex; gap: 15px; align-items: center; padding: 15px 20px;">
            <input type="file" id="excelFileInput" class="form-control" accept=".xlsx, .xls" style="max-width: 350px;">
            <button onclick="importExcelData('taxes')" class="btn btn-primary" style="background: #1E88E5; border-color: #1E88E5; margin-top:0;">
              <i class="fas fa-upload"></i> Parse & Import
            </button>
          </div>
        </div>

        <!-- Add New Tax Record Form -->
        <div class="card mb-4">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-plus"></i> Add New Tax Record</h3>
          </div>
          <div class="card-body">
            <form id="taxRecordForm" method="POST" action="/api/admin/add-tax">
              <div class="form-row">
                <div class="form-group">
                  <label for="propertyId" class="form-label">Property ID</label>
                  <input type="text" id="propertyId" name="propertyId" class="form-control" placeholder="e.g., PROP001" required>
                </div>
                <div class="form-group">
                  <label for="ownerName" class="form-label">Owner Name</label>
                  <input type="text" id="ownerName" name="ownerName" class="form-control" placeholder="Owner name">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="taxAmount" class="form-label">Tax Amount</label>
                  <input type="number" id="taxAmount" name="taxAmount" class="form-control" placeholder="2500" step="0.01" required>
                </div>
                <div class="form-group">
                  <label for="dueDate" class="form-label">Due Date</label>
                  <input type="date" id="dueDate" name="dueDate" class="form-control" required>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="year" class="form-label">Year</label>
                  <input type="number" id="year" name="year" class="form-control" placeholder="2026" required>
                </div>
                <div class="form-group">
                  <label for="status" class="form-label">Status</label>
                  <select id="status" name="status" class="form-control" required>
                    <option value="Pending" selected>Pending</option>
                    <option value="Paid">Paid</option>
                    <option value="Overdue">Overdue</option>
                  </select>
                </div>
              </div>
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Tax Record</button>
                <button type="reset" class="btn btn-outline">Reset</button>
              </div>
            </form>
          </div>
        </div>

        <!-- Tax Records Table -->
        <div class="card table-container">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-list"></i> Tax Records</h3>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table">
                <thead>
                  <tr>
                    <th>Property ID</th>
                    <th>Owner</th>
                    <th>Amount</th>
                    <th>Due Date</th>
                    <th>Year</th>
                    <th>Status</th>
                    <th>ML Default Risk</th>
                    <th>Created</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (taxRecords.length === 0) { %>
                    <tr>
                      <td colspan="9" class="text-center text-muted py-4">
                        <i class="fas fa-inbox fa-3x mb-3"></i><br>
                        No tax records found
                      </td>
                    </tr>
                  <% } else { %>
                    <% taxRecords.forEach(record => { %>
                      <tr>
                        <td><strong><%= record.property_id %></strong></td>
                        <td><%= record.owner_name %></td>
                        <td>₹<%= parseFloat(record.tax_amount).toLocaleString('en-IN') %></td>
                        <td><%= new Date(record.due_date).toLocaleDateString('en-IN') %></td>
                        <td><%= record.year %></td>
                        <td>
                          <span class="status-badge <%= record.status.toLowerCase() %>"><%= record.status %></span>
                        </td>
                        <td>
                          <div style="display: flex; flex-direction: column; gap: 4px;">
                            <div>
                              <% const displayRisk = record.override_status || record.predicted_status || 'No Risk'; %>
                              <span class="status-badge <%= displayRisk === 'High Risk' ? 'overdue' : (displayRisk === 'Medium Risk' || displayRisk === 'Low Risk') ? 'unpaid' : 'paid' %>">
                                <%= displayRisk %> (<%= Math.round(record.payment_probability || 0) %>%)
                              </span>
                              <% if (record.override_status) { %>
                                <small class="text-success" title="Admin Overridden: ML model predicted <%= record.predicted_status %>"><i class="fas fa-check-circle"></i></small>
                                <div style="font-size:0.75rem; color:#666; margin-top:2px;">(ML: <%= record.predicted_status %>)</div>
                              <% } %>
                            </div>
                            <% if (record.xai_explanation) { %>
                              <small class="text-muted" style="font-size: 0.73rem; font-style: italic; line-height: 1.1; margin-top: 2px;">
                                <i class="fas fa-info-circle"></i> <%= record.xai_explanation %>
                              </small>
                            <% } %>
                            <% if (record.status !== 'Paid') { %>
                              <!-- Override Select -->
                              <select class="form-control form-control-sm" style="width: auto; font-size: 0.75rem; margin-top: 4px; padding: 2px 5px;" onchange="overrideTaxRisk('<%= record.id %>', this.value)">
                                <option value="">Override Risk...</option>
                                <option value="Low Risk" <%= record.override_status === 'Low Risk' ? 'selected' : '' %>>Low Risk</option>
                                <option value="Medium Risk" <%= record.override_status === 'Medium Risk' ? 'selected' : '' %>>Medium Risk</option>
                                <option value="High Risk" <%= record.override_status === 'High Risk' ? 'selected' : '' %>>High Risk</option>
                              </select>
                            <% } %>
                          </div>
                        </td>
                        <td><small><%= new Date(record.created_at).toLocaleDateString('en-IN') %></small></td>
                        <td>
                          <div class="table-actions">
                            <button class="btn btn-sm btn-outline" onclick="editTaxRecord(this)"
                                    data-id="<%= record.id %>"
                                    data-property-id="<%= record.property_id %>"
                                    data-tax-amount="<%= record.tax_amount %>"
                                    data-due-date="<%= record.due_date %>"
                                    data-year="<%= record.year %>"
                                    data-status="<%= record.status %>">
                              <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteTaxRecord(this)"
                                    data-id="<%= record.id %>">
                              <i class="fas fa-trash"></i>
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Edit Tax Modal -->
  <div id="editTaxModal" class="modal-overlay">
    <div class="modal">
      <div class="modal-header">
        <h3>Edit Tax Record</h3>
        <button class="modal-close" onclick="closeEditTaxModal()"><i class="fas fa-times"></i></button>
      </div>
      <form id="editTaxForm" method="POST" action="/api/admin/update-tax">
        <div class="modal-body">
          <input type="hidden" id="editTaxId" name="id">
          <input type="hidden" id="editPropertyId" name="propertyId">
          <div class="form-row">
            <div class="form-group">
              <label for="editTaxAmount" class="form-label">Tax Amount</label>
              <input type="number" id="editTaxAmount" name="taxAmount" class="form-control" step="0.01" required>
            </div>
            <div class="form-group">
              <label for="editDueDate" class="form-label">Due Date</label>
              <input type="date" id="editDueDate" name="dueDate" class="form-control" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="editYear" class="form-label">Year</label>
              <input type="number" id="editYear" name="year" class="form-control" required>
            </div>
            <div class="form-group">
              <label for="editStatus" class="form-label">Status</label>
              <select id="editStatus" name="status" class="form-control" required>
                <option value="Pending">Pending</option>
                <option value="Paid">Paid</option>
                <option value="Overdue">Overdue</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline" onclick="closeEditTaxModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Update Record</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/main.js?v=<%= Date.now() %>"></script>
  <script>
    // Set default due date to end of year
    document.getElementById('dueDate').valueAsDate = new Date(new Date().getFullYear(), 11, 31);
    document.getElementById('year').value = new Date().getFullYear();

    const editModal = document.getElementById('editTaxModal');

    function editTaxRecord(btn) {
      document.getElementById('editTaxId').value = btn.dataset.id;
      document.getElementById('editPropertyId').value = btn.dataset.propertyId;
      document.getElementById('editTaxAmount').value = btn.dataset.taxAmount;
      document.getElementById('editDueDate').value = btn.dataset.dueDate;
      document.getElementById('editYear').value = btn.dataset.year;
      document.getElementById('editStatus').value = btn.dataset.status;
      editModal.classList.add('active');
    }

    function closeEditTaxModal() {
      editModal.classList.remove('active');
    }

    function overrideTaxRisk(id, risk) {
      fetch('/api/admin/override-tax-prediction', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, risk })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          window.location.reload();
        } else {
          alert("Error applying override: " + data.error);
        }
      })
      .catch(err => alert("Network error: " + err.message));
    }

    function deleteTaxRecord(btn) {
      if (confirm("Are you sure you want to delete this tax record?")) {
        fetch('/api/admin/delete-tax', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: btn.dataset.id })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            window.location.reload();
          } else {
            alert("Error deleting record: " + data.message);
          }
        });
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script>
    function importExcelData(type) {
      const fileInput = document.getElementById('excelFileInput');
      if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
        alert('Please select an Excel file first.');
        return;
      }
      const file = fileInput.files[0];
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const data = new Uint8Array(e.target.result);
          const workbook = XLSX.read(data, { type: 'array' });
          const firstSheetName = workbook.SheetNames[0];
          const worksheet = workbook.Sheets[firstSheetName];
          const jsonData = XLSX.utils.sheet_to_json(worksheet);
          
          if (jsonData.length === 0) {
            alert('The Excel file is empty.');
            return;
          }
          
          fetch('/api/admin/import', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: type, data: jsonData })
          })
          .then(res => res.json())
          .then(resData => {
            alert(resData.message);
            if (resData.success) {
              window.location.reload();
            }
          });
        } catch(err) {
          alert('Error parsing Excel: ' + err.message);
        }
      };
      reader.readAsArrayBuffer(file);
    }
  </script>
</body>
</html>
