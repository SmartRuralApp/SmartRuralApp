<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Grama Panchayat - Home</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Header -->
  <header class="header">
    <nav class="navbar">
      <a href="/" class="logo">
        <div class="logo-icon">
          <i class="fas fa-landmark"></i>
        </div>
        <span class="logo-text">Smart Grama Panchayat</span>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="active"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="/tax-search"><i class="fas fa-search-dollar"></i> Tax Payment</a></li>
        <li><a href="/services"><i class="fas fa-handshake"></i> Services</a></li>
        <li><a href="/admin-login"><i class="fas fa-user-shield"></i> Admin</a></li>
      </ul>
      <button class="mobile-menu-btn">
        <i class="fas fa-bars"></i>
      </button>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1>Welcome to Smart Grama Panchayat</h1>
        <p>Digitizing Panchayat services for easier access to citizen services. Pay your taxes, access services, and stay updated - all in one place.</p>
        <div class="hero-buttons">
          <a href="/tax-search" class="btn btn-primary">
            <i class="fas fa-search"></i> Pay Tax
          </a>
          <a href="/services" class="btn btn-secondary">
            <i class="fas fa-info-circle"></i> View Services
          </a>
        </div>
      </div>
    </section>

    <div class="container">
      <!-- Reminder Section -->
<% if (false) { %>
        <!-- Reminders section placeholder - disabled to avoid errors -->
      <% } %>


      <!-- Stats Section -->
      <h2 class="mb-3">Panchayat Overview</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon green">
            <i class="fas fa-rupee-sign"></i>
          </div>
          <div class="stat-info">
            <h3>₹<%= (stats.collection || 0).toLocaleString('en-IN') %></h3>
            <p>Total Collection</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange">
            <i class="fas fa-clock"></i>
          </div>
          <div class="stat-info">
            <h3><%= (stats.pending || 0) %></h3>
            <p>Pending Payments</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue">
            <i class="fas fa-home"></i>
          </div>
          <div class="stat-info">
            <h3><%= stats.properties %></h3>
            <p>Registered Properties</p>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <h2 class="mb-3 mt-4">Quick Actions</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-search-dollar"></i>
          </div>
          <h3 class="service-title">Search & Pay Tax</h3>
          <p class="service-description">Search your property tax details by Property ID or Owner Name and pay online.</p>
          <a href="/tax-search" class="btn btn-primary mt-2">Search Now</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-clipboard-list"></i>
          </div>
          <h3 class="service-title">View Services</h3>
          <p class="service-description">Browse all available Panchayat services and their requirements.</p>
          <a href="/services" class="btn btn-primary mt-2">View Services</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-bullhorn"></i>
          </div>
          <h3 class="service-title">Announcements</h3>
          <p class="service-description">Stay updated with latest news and announcements from the Panchayat.</p>
          <a href="/services" class="btn btn-outline mt-2">View Updates</a>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-content">
      <div class="footer-logo">Smart Grama Panchayat</div>
      <p>Digitizing Rural Governance | All Rights Reserved</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>

