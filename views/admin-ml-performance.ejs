<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ML Performance - Smart Grama Panchayat</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <i class="fas fa-landmark"></i>
          <span>Panchayat Admin</span>
        </div>
      </div>
            <ul class="sidebar-menu">
        <li><a href="/admin-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li><a href="/admin-properties"><i class="fas fa-city"></i> Properties</a></li>
        <li><a href="/admin-citizens"><i class="fas fa-users"></i> Citizens</a></li>
        <li><a href="/admin-tax"><i class="fas fa-receipt"></i> Tax Management</a></li>
        <li><a href="/admin-reminders"><i class="fas fa-bell"></i> SMS Reminders</a></li>
        
        <li><a href="/admin-complaints"><i class="fas fa-exclamation-triangle"></i> Complaints</a></li>
        <li><a href="/admin-services"><i class="fas fa-cogs"></i> Services</a></li>
        <li><a href="/admin-schemes"><i class="fas fa-hand-holding-usd"></i> Schemes</a></li>
        <li><a href="/admin-ml-performance" class="active"><i class="fas fa-chart-line"></i> ML Performance</a></li>
        <li><a href="/admin-logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
      <div class="admin-header">
        <div>
          <h1>Machine Learning Performance</h1>
          <p class="text-muted">Explainable AI Accuracy, Precision, & Confusion Matrices</p>
        </div>
      </div>

      <% if (metadata) { %>
        <div class="card mb-4" style="background: linear-gradient(135deg, #1565C0 0%, #0D47A1 100%); color: white;">
          <div class="card-body d-flex justify-between align-items-center flex-wrap" style="padding: 1.5rem; gap: 15px;">
            <div>
              <h3>Active Models Version: <strong><%= metadata.version %></strong></h3>
              <p style="opacity: 0.9;">Trained on Excel Datasets incorporating admin feedback loops.</p>
            </div>
            <div>
              <p><i class="fas fa-calendar-check"></i> Last Retrained: <strong><%= metadata.last_trained %></strong></p>
            </div>
          </div>
        </div>

        <!-- Models Cards -->
        <% const modelKeys = {
          complaint_priority: "Complaint Priority Classifier",
          tax_defaulter: "Tax Payment Defaulter Predictor",
          scheme_recommender: "Government Scheme Eligibility Recommender"
        }; %>

        <div style="display: flex; flex-direction: column; gap: 30px;">
          <% Object.keys(modelKeys).forEach(key => { %>
            <% const model = metadata.models[key]; %>
            <% if (model) { %>
              <div class="card">
                <div class="card-header" style="border-bottom: 2px solid #F5F5F5;">
                  <h3 class="card-title" style="color: var(--secondary); font-weight:600;">
                    <i class="fas fa-microchip"></i> <%= modelKeys[key] %>
                  </h3>
                  <span class="status-badge active" style="background: #E3F2FD; color: #1565C0;">Size: <%= model.dataset_size %> samples</span>
                </div>
                <div class="card-body">
                  <!-- Metrics Grid -->
                  <div class="metrics-summary-grid mt-3">
                    <div class="metric-box">
                      <span class="label">Accuracy</span>
                      <span class="value"><%= (model.accuracy * 100).toFixed(2) %>%</span>
                    </div>
                    <div class="metric-box">
                      <span class="label">Precision</span>
                      <span class="value"><%= (model.precision * 100).toFixed(2) %>%</span>
                    </div>
                    <div class="metric-box">
                      <span class="label">Recall</span>
                      <span class="value"><%= (model.recall * 100).toFixed(2) %>%</span>
                    </div>
                    <div class="metric-box">
                      <span class="label">F1-Score</span>
                      <span class="value"><%= (model.f1_score * 100).toFixed(2) %>%</span>
                    </div>
                  </div>
                  
                  <% if (model.comparison) { %>
                    <div class="mt-4" style="border-top: 1px solid #EEE; padding-top: 20px; margin-bottom: 20px;">
                      <h4 style="font-size: 0.95rem; margin-bottom: 12px; color: var(--text-primary);">
                        <i class="fas fa-balance-scale"></i> Classifier Models Comparison
                      </h4>
                      <div class="table-responsive">
                        <table class="table" style="font-size: 0.85rem; width: 100%; border-collapse: collapse; margin-bottom: 15px;">
                          <thead>
                            <tr style="background-color: #F5F5F5;">
                              <th style="padding: 10px; border: 1px solid #DDD; text-align: left; font-weight: 600;">Model Name</th>
                              <th style="padding: 10px; border: 1px solid #DDD; text-align: center; font-weight: 600;">Accuracy</th>
                              <th style="padding: 10px; border: 1px solid #DDD; text-align: center; font-weight: 600;">Precision</th>
                              <th style="padding: 10px; border: 1px solid #DDD; text-align: center; font-weight: 600;">Recall</th>
                              <th style="padding: 10px; border: 1px solid #DDD; text-align: center; font-weight: 600;">F1-Score</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% model.comparison.forEach(m => { %>
                              <tr style="<%= m.model_name === model.selected_model ? 'background-color: #E8F5E9; font-weight: 600;' : '' %>">
                                <td style="padding: 10px; border: 1px solid #DDD; text-align: left; vertical-align: middle;">
                                  <%= m.model_name %>
                                  <% if (m.model_name === model.selected_model) { %>
                                    <span class="status-badge active" style="font-size: 0.7rem; padding: 2px 6px; margin-left: 8px; background: #C8E6C9; color: #2E7D32;">Selected</span>
                                  <% } %>
                                </td>
                                <td style="padding: 10px; border: 1px solid #DDD; text-align: center; vertical-align: middle;"><%= (m.accuracy * 100).toFixed(2) %>%</td>
                                <td style="padding: 10px; border: 1px solid #DDD; text-align: center; vertical-align: middle;"><%= (m.precision * 100).toFixed(2) %>%</td>
                                <td style="padding: 10px; border: 1px solid #DDD; text-align: center; vertical-align: middle;"><%= (m.recall * 100).toFixed(2) %>%</td>
                                <td style="padding: 10px; border: 1px solid #DDD; text-align: center; vertical-align: middle;"><%= (m.f1_score * 100).toFixed(2) %>%</td>
                              </tr>
                            <% }); %>
                          </tbody>
                        </table>
                      </div>
                      <div class="alert alert-success" style="padding: 12px 18px; border-radius: var(--radius-sm); background: #E8F5E9; border-left: 4px solid #2E7D32; color: #1B5E20; font-size: 0.88rem; line-height: 1.4;">
                        <strong>Selected Model:</strong> <%= model.selected_model %> <br>
                        <span style="font-size: 0.83rem; font-style: italic; display: block; margin-top: 4px; opacity: 0.95;">
                          <i class="fas fa-info-circle"></i> <%= model.selection_reason %>
                        </span>
                      </div>
                      
                      <!-- Model Comparison Grouped Bar Chart Graph -->
                      <div class="mt-4 mb-2" style="border-top: 1px solid #EEE; padding-top: 20px;">
                        <h4 style="font-size: 0.95rem; margin-bottom: 12px; color: var(--text-primary);"><i class="fas fa-chart-bar"></i> Performance Comparison Graph</h4>
                        <div style="text-align: center;">
                          <img src="/img/comparison_<%= key %>.png?v=<%= Date.now() %>" alt="Model comparison chart for <%= key %>" style="max-width: 100%; height: auto; border: 1px solid #E0E0E0; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
                        </div>
                      </div>
                    </div>
                  <% } %>

                  <!-- Confusion Matrix -->
                  <div class="mt-4">
                    <h4 style="font-size: 0.95rem; margin-bottom: 12px; color: var(--text-primary);"><i class="fas fa-th"></i> Confusion Matrix (Validation Split)</h4>
                    <div class="table-responsive" style="max-width: 500px;">
                      <table class="cm-table">
                        <thead>
                          <tr>
                            <th></th>
                            <th colspan="<%= model.classes.length %>" style="text-align: center; border-bottom: 2px solid #DDD;">Predicted Class</th>
                          </tr>
                          <tr>
                            <th style="border-right: 2px solid #DDD;">Actual Class</th>
                            <% model.classes.forEach(c => { %>
                              <th style="font-size: 0.8rem; text-align: center;"><%= c %></th>
                            <% }); %>
                          </tr>
                        </thead>
                        <tbody>
                          <% model.confusion_matrix.forEach((row, i) => { %>
                            <tr>
                              <td style="font-weight: 600; font-size: 0.85rem; border-right: 2px solid #DDD;"><%= model.classes[i] %></td>
                              <% row.forEach((val, j) => { %>
                                <td style="text-align: center; background-color: <%= i === j ? '#E8F5E9' : '#FFEBEE' %>; font-weight: <%= i === j ? 'bold' : 'normal' %>;">
                                  <%= val %>
                                </td>
                              <% }); %>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            <% } %>
          <% }); %>
        </div>
      <% } else { %>
        <div class="card text-center py-5">
          <i class="fas fa-info-circle fa-3x mb-3 text-muted"></i>
          <h3>No ML Metadata Found</h3>
          <p class="text-muted">Export data and run model retraining to initialize model metrics.</p>
        </div>
      <% } %>
    </main>
  </div>

  <style>
    .metrics-summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
    }
    .metric-box {
      background: #F8F9FA;
      border: 1px solid #EAEAEA;
      border-radius: var(--radius-sm);
      padding: 15px;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .metric-box .label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .metric-box .value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary);
    }
    .cm-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    .cm-table th, .cm-table td {
      border: 1px solid #E0E0E0;
      padding: 10px;
    }
    .cm-table th {
      background-color: #F5F5F5;
      font-weight: 600;
    }
  </style>
</body>
</html>
