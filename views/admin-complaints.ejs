<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Complaints Management - Admin | Smart Grama Panchayat</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&amp;family=Open+Sans:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
</head>
<body>
  <nav class="header">
    <div class="navbar">
      <div class="logo">
        <div class="logo-icon"><i class="fas fa-landmark"></i></div>
        <div class="logo-text">Panchayat Admin</div>
      </div>
      <ul class="nav-links">
        <li><a href="/admin-dashboard" class="nav-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li><a href="/admin-tax" class="nav-link"><i class="fas fa-receipt"></i> Tax Management</a></li>
        <li><a href="/admin-services" class="nav-link"><i class="fas fa-cogs"></i> Services</a></li>
        <li><a href="/admin-logout" class="nav-link"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
      <button class="mobile-menu-btn"><i class="fas fa-bars"></i></button>
    </div>
  </nav>

  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <i class="fas fa-shield-alt"></i> Admin
        </div>
      </div>
      <ul class="sidebar-menu">
        <li><a href="/admin-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li><a href="/admin-properties"><i class="fas fa-city"></i> Properties</a></li>
        <li><a href="/admin-citizens"><i class="fas fa-users"></i> Citizens</a></li>
        <li><a href="/admin-tax"><i class="fas fa-receipt"></i> Tax Management</a></li>
        <li><a href="/admin-reminders"><i class="fas fa-bell"></i> SMS Reminders</a></li>
        <li><a href="/admin-appointments"><i class="fas fa-calendar-check"></i> Appointments</a></li>
        <li><a href="/admin-complaints" class="active"><i class="fas fa-exclamation-triangle"></i> Complaints</a></li>
        <li><a href="/admin-services"><i class="fas fa-cogs"></i> Services</a></li>
        <li><a href="/admin-schemes"><i class="fas fa-hand-holding-usd"></i> Schemes</a></li>
        <li><a href="/admin-ml-performance"><i class="fas fa-chart-line"></i> ML Performance</a></li>
        <li><a href="/admin-logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
    </aside>

    <main class="admin-content">
      <div class="container">
        <div class="admin-header">
          <div>
            <h1>Citizen Complaints Management</h1>
            <p class="text-muted">Review, update status, and override Machine Learning priority predictions.</p>
          </div>
        </div>

        <!-- Duplicate Complaints & Impact Analysis Tracker -->
        <div class="card mb-4" style="border-left: 5px solid #FF8F00;">
          <div class="card-header" style="background: #FFF8E1; display: flex; justify-content: space-between; align-items: center;">
            <h3 class="card-title" style="color: #FF8F00; margin: 0;"><i class="fas fa-copy"></i> Duplicate Complaints & Impact Analysis</h3>
            <span class="status-badge orange" style="margin: 0; font-size: 0.8rem;">
              <%= duplicatesAnalysis.length %> Issues with Duplicates
            </span>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table" style="font-size: 0.85rem;">
                <thead>
                  <tr style="background: #FFF3E0;">
                    <th>Original ID</th>
                    <th>Category</th>
                    <th>Ward</th>
                    <th>Current Priority</th>
                    <th>Status</th>
                    <th>Linked Duplicate IDs</th>
                    <th>Affected Citizens / Duplicates</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (duplicatesAnalysis.length === 0) { %>
                    <tr>
                      <td colspan="7" class="text-center text-muted py-3">No duplicate groups cluster detected yet.</td>
                    </tr>
                  <% } else { %>
                    <% duplicatesAnalysis.forEach(group => { %>
                      <tr>
                        <td><strong>#<%= group.original_id %></strong></td>
                        <td><span class="status-badge active" style="background: #E8EAF6; color: #3F51B5;"><%= group.category %></span></td>
                        <td><%= group.ward %></td>
                        <td>
                          <span class="status-badge <%= (group.priority === 'Critical' || group.priority === 'High') ? 'overdue' : group.priority === 'Medium' ? 'unpaid' : 'paid' %>" style="<%= group.priority === 'Critical' ? 'background: #4A148C; color: white;' : '' %>">
                            <%= group.priority %>
                          </span>
                        </td>
                        <td>
                          <span class="status-badge <%= group.status === 'Resolved' ? 'paid' : group.status === 'In Progress' ? 'unpaid' : 'inactive' %>">
                            <%= group.status %>
                          </span>
                        </td>
                        <td><span class="text-danger" style="font-weight: 500;">#<%= group.linked_ids %></span></td>
                        <td>
                          <strong><%= group.duplicates_count %> duplicate(s)</strong><br>
                          <small class="text-muted">Owners: <%= group.affected_citizens %></small>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Complaints Table -->
        <div class="card table-container">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-list-ul"></i> Citizen Complaints Feed</h3>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table">
                <thead>
                  <tr>
                    <th>Property ID & Owner</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Ward</th>
                    <th>ML Priority Rating</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (complaints.length === 0) { %>
                    <tr>
                      <td colspan="8" class="text-center text-muted py-4">
                        No complaints submitted yet
                      </td>
                    </tr>
                  <% } else { %>
                    <% complaints.forEach(function(complaint) { %>
                      <tr style="<%= complaint.is_duplicate ? 'background-color: #FFFDF0;' : '' %>">
                        <td>
                          <strong><%= complaint.property_id %></strong><br>
                          <small class="text-muted"><%= complaint.owner_name %></small>
                        </td>
                        <td>
                          <span class="status-badge active" style="background: #E8EAF6; color: #3F51B5;"><%= complaint.category %></span>
                          <% if (complaint.admin_corrected) { %>
                            <br><small class="text-success" style="font-weight: 600;"><i class="fas fa-check-circle"></i> Overridden</small>
                          <% } %>
                        </td>
                        <td style="max-width: 250px;">
                          <div style="font-size: 0.9rem; line-height: 1.3;"><%= complaint.description %></div>
                          <% if (complaint.xai_explanation) { %>
                            <div style="font-size: 0.75rem; color: #78909C; margin-top: 5px; font-style: italic;">
                              <i class="fas fa-info-circle"></i> XAI: <%= complaint.xai_explanation %>
                            </div>
                          <% } %>
                          <% if (complaint.is_duplicate) { %>
                            <div class="mt-1">
                              <span class="status-badge overdue" style="font-size: 0.75rem; padding: 2px 8px; background: #FFEBEE; color: #C62828;">
                                <i class="fas fa-copy"></i> Duplicate of ID #<%= complaint.duplicate_of_id %>
                              </span>
                            </div>
                          <% } %>
                        </td>
                        <td><%= complaint.ward %></td>
                        <td>
                          <span class="status-badge <%= (complaint.priority === 'Critical' || complaint.priority === 'High') ? 'overdue' : complaint.priority === 'Medium' ? 'unpaid' : 'paid' %>" style="<%= complaint.priority === 'Critical' ? 'background: #4A148C; color: white;' : '' %>" title="Admin Approved Priority">
                            <%= complaint.priority %>
                          </span>
                          <% if (complaint.admin_corrected) { %>
                            <div style="font-size: 0.75rem; color: #78909C; margin-top: 4px;">
                              <i class="fas fa-brain"></i> ML predicted: <strong><%= complaint.predicted_priority %></strong>
                            </div>
                          <% } %>
                          <% if (complaint.confidence_score) { %>
                            <br><small class="text-muted">Conf: <%= Math.round(complaint.confidence_score * 100) %>%</small>
                          <% } %>
                        </td>
                        <td>
                          <span class="status-badge <%= complaint.status === 'Resolved' ? 'paid' : complaint.status === 'In Progress' ? 'unpaid' : 'inactive' %>">
                            <%= complaint.status %>
                          </span>
                        </td>
                        <td><small><%= new Date(complaint.created_at).toLocaleDateString('en-IN') %></small></td>
                        <td>
                          <div class="table-actions">
                            <!-- Status Update -->
                            <select class="form-control form-control-sm" style="width: auto; padding: 4px 8px;" onchange="updateStatus('<%= complaint.id %>', this.value)">
                              <option value="Pending" <%= complaint.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                              <option value="In Progress" <%= complaint.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                              <option value="Resolved" <%= complaint.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                            </select>
                            
                            <!-- Override Button -->
                            <button class="btn btn-sm btn-outline" title="Override Prediction" onclick="openOverrideModal('<%= complaint.id %>', '<%= complaint.category %>', '<%= complaint.priority %>')">
                              <i class="fas fa-edit"></i>
                            </button>

                            <!-- Delete Button -->
                            <button class="btn btn-sm btn-danger-outline" style="padding: 4px 8px; border: 1px solid #c62828; color: #c62828; background: transparent; border-radius: 4px; cursor: pointer;" title="Delete Complaint" onclick="deleteComplaint('<%= complaint.id %>')">
                              <i class="fas fa-trash-alt"></i>
                            </button>
                          </div>                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Override Modal -->
  <div class="modal-overlay" id="overrideModal">
    <div class="modal">
      <div class="modal-header">
        <h3>Override ML Predictions</h3>
        <button class="modal-close" onclick="closeOverrideModal()">&times;</button>
      </div>
      <div class="modal-body">
        <form id="overrideForm">
          <input type="hidden" id="overrideComplaintId">
          <div class="form-group">
            <label class="form-label" for="overrideCategory">Category</label>
            <select class="form-control" id="overrideCategory" required>
              <option value="Water Supply">Water Supply</option>
              <option value="Road Damage">Road Damage</option>
              <option value="Street Light">Street Light</option>
              <option value="Sanitation">Sanitation</option>
              <option value="Drainage">Drainage</option>
              <option value="Electricity">Electricity</option>
              <option value="Others">Others</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="overridePriority">Priority Rating</label>
            <select class="form-control" id="overridePriority" required>
              <option value="Critical">Critical Priority</option>
              <option value="High">High Priority</option>
              <option value="Medium">Medium Priority</option>
              <option value="Low">Low Priority</option>
            </select>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="closeOverrideModal()">Cancel</button>
        <button class="btn btn-primary" onclick="submitOverride()">Apply Override</button>
      </div>
    </div>
  </div>

  <script src="/js/main.js?v=<%= Date.now() %>"></script>
  <script>
    const modal = document.getElementById("overrideModal");

    function openOverrideModal(id, cat, prio) {
      document.getElementById("overrideComplaintId").value = id;
      document.getElementById("overrideCategory").value = cat;
      document.getElementById("overridePriority").value = prio;
      modal.classList.add("active");
    }

    function closeOverrideModal() {
      modal.classList.remove("active");
    }

    function submitOverride() {
      const id = document.getElementById("overrideComplaintId").value;
      const category = document.getElementById("overrideCategory").value;
      const priority = document.getElementById("overridePriority").value;

      fetch("/api/admin/override-complaint", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id, category, priority })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          closeOverrideModal();
          window.location.reload();
        } else {
          alert("Error: " + data.message);
        }
      });
    }
    function deleteComplaint(id) {
      if (!confirm("Are you sure you want to delete this complaint permanently?")) return;
      fetch('/api/admin/delete-complaint', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          window.location.reload();
        } else {
          alert("Error deleting complaint: " + data.error);
        }
      });
    }

    function updateStatus(id, status) {
      const remarks = prompt("Enter resolution remarks or action taken updates (optional):");
      if (remarks === null) {
        window.location.reload();
        return;
      }
      fetch('/api/admin/update-complaint-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status, remarks })
      })
      .then(res => res.json())
      .then(data => {
        if (!data.success) {
          alert("Error updating status: " + data.error);
        } else {
          window.location.reload();
        }
      });
    }
  </script>
</body>
</html>
