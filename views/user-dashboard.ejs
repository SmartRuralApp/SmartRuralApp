<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Citizen Dashboard - Smart Grama Panchayat</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --gov-primary: #1B5E20;
      --gov-secondary: #2E7D32;
      --gov-accent: #E8F5E9;
      --card-border: #ECEFF1;
      --bg-dark: #37474F;
      --danger-red: #D32F2F;
    }
    
    body {
      background-color: #F4F6F7;
      font-family: 'Open Sans', sans-serif;
    }
    
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Poppins', sans-serif;
    }

    /* Modern Navbar styling */
    .header {
      background: white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
      padding: 10px 0;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
    }
    
    .logo-text {
      font-weight: 700;
      color: var(--gov-primary);
      font-size: 1.25rem;
    }
    
    .nav-links a {
      color: #455A64;
      font-weight: 500;
      transition: color 0.2s;
    }
    
    .nav-links a:hover, .nav-links a.active {
      color: var(--gov-primary) !important;
    }

    /* Red Logout Button */
    .logout-btn {
      background: var(--danger-red) !important;
      color: white !important;
      font-weight: 600 !important;
      padding: 8px 20px !important;
      border-radius: 6px !important;
      border: none !important;
      box-shadow: 0 4px 10px rgba(211,47,47,0.25) !important;
      transition: all 0.2s ease !important;
      display: inline-flex !important;
      align-items: center !important;
      gap: 8px !important;
    }
    
    .logout-btn:hover {
      background: #B71C1C !important;
      box-shadow: 0 6px 14px rgba(183,28,28,0.35) !important;
      transform: translateY(-1px);
    }

    /* Section Cards - Modified height to auto to prevent height overlap issues */
    .dashboard-card {
      background: white;
      border: 1px solid var(--card-border);
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.02);
      padding: 24px;
      margin-bottom: 30px;
      display: flex;
      flex-direction: column;
      height: auto;
      width: 100%;
    }

    .card-header-custom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--card-border);
      padding-bottom: 12px;
      margin-bottom: 20px;
    }
    
    .card-title-custom {
      margin: 0;
      color: var(--gov-primary);
      font-weight: 600;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* Details Grid */
    .details-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }
    
    .details-group {
      border: 1px solid #ECEFF1;
      border-radius: 8px;
      padding: 15px;
      background: #FAFAFA;
    }
    
    .details-group-title {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--gov-primary);
      margin-bottom: 12px;
      border-bottom: 1px solid #E0E0E0;
      padding-bottom: 6px;
    }

    .profile-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.9rem;
      color: #546E7A;
      margin-bottom: 8px;
    }
    
    .profile-item i {
      color: var(--gov-secondary);
      width: 20px;
      text-align: center;
    }

    .profile-item:last-child {
      margin-bottom: 0;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header class="header">
    <nav class="navbar" style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 20px;">
      <a href="/" class="logo" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
        <div class="logo-icon" style="width: 40px; height: 40px; background: var(--gov-accent); color: var(--gov-primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem;">
          <i class="fas fa-landmark"></i>
        </div>
        <span class="logo-text">Smart Grama Panchayat</span>
      </a>
      <ul class="nav-links" style="display: flex; list-style: none; gap: 20px; margin: 0; padding: 0; align-items: center;">
        <li><a href="/" style="text-decoration: none;"><i class="fas fa-home"></i> Home</a></li>
        <li><a href="/services" style="text-decoration: none;"><i class="fas fa-handshake"></i> Services</a></li>
        <li><a href="/user-dashboard" class="active" style="text-decoration: none;"><i class="fas fa-user-circle"></i> Portal Dashboard</a></li>
        <li><a href="/user-logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
      </ul>
    </nav>
  </header>

  <!-- Citizen Layout Container -->
  <main class="container py-4" style="max-width: 1200px; margin: 0 auto; padding: 100px 20px 40px 20px;">
    
    <!-- 1. Welcome Header Section -->
    <div class="card mb-4" style="border-radius: 12px; background: linear-gradient(135deg, var(--gov-primary) 0%, #0d3c11 100%); color: white; padding: 25px; border: none; box-shadow: 0 6px 20px rgba(0,0,0,0.08); margin-bottom: 30px;">
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 20px; flex-wrap: wrap;">
        <div>
          <h1 style="color: white; font-weight: 700; margin: 0 0 8px 0; font-size: 1.8rem;">Welcome, <%= session.user.name %>!</h1>
          <div style="display: flex; gap: 20px; flex-wrap: wrap; opacity: 0.95; font-size: 0.95rem;">
            <span><i class="fas fa-id-badge" style="margin-right: 6px;"></i> <strong>Citizen ID:</strong> <%= session.user.id %></span>
            <span><i class="fas fa-id-card" style="margin-right: 6px;"></i> <strong>Property ID:</strong> <%= session.user.property_id %></span>
            <span><i class="fas fa-landmark" style="margin-right: 6px;"></i> <strong>Ward Number:</strong> <%= session.user.ward || 'Ward 1' %></span>
          </div>
        </div>
        <div style="background: rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: 8px; font-size: 0.85rem; line-height: 1.5; min-width: 260px;">
          <i class="fas fa-phone"></i> <strong>Mobile:</strong> <%= session.user.phone %><br>
          <i class="fas fa-envelope"></i> <strong>Email:</strong> <%= session.user.email || 'N/A' %><br>
          <i class="fas fa-map-marker-alt"></i> <strong>Address:</strong> <%= session.user.address || (property ? property.address : 'N/A') %>
        </div>
      </div>
    </div>

    <!-- 2. Dashboard Summary Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-bottom: 30px;">
      <!-- Tax Summary -->
      <div class="card" style="background: white; border: 1px solid var(--card-border); border-radius: 12px; padding: 20px; display: flex; align-items: center; gap: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
        <div style="width: 50px; height: 50px; border-radius: 50%; background: #FFF3E0; color: #E65100; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
          <i class="fas fa-file-invoice-dollar"></i>
        </div>
        <div>
          <% 
            let unpaidTaxTotal = 0; 
            taxRecords.forEach(r => {
              if (r.status !== 'Paid') unpaidTaxTotal += r.tax_amount;
            });
          %>
          <h3 style="margin: 0; font-size: 1.4rem; color: #263238;">₹<%= unpaidTaxTotal.toLocaleString('en-IN') %></h3>
          <p style="margin: 0; font-size: 0.85rem; color: #78909C;">Outstanding Property Tax</p>
        </div>
      </div>
      <!-- Grievance Summary -->
      <div class="card" style="background: white; border: 1px solid var(--card-border); border-radius: 12px; padding: 20px; display: flex; align-items: center; gap: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
        <div style="width: 50px; height: 50px; border-radius: 50%; background: #E8F5E9; color: #2E7D32; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
          <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div>
          <% 
            let activeComplaintsCount = complaints.filter(c => c.status !== 'Resolved').length;
          %>
          <h3 style="margin: 0; font-size: 1.4rem; color: #263238;"><%= activeComplaintsCount %></h3>
          <p style="margin: 0; font-size: 0.85rem; color: #78909C;">Active Grievances</p>
        </div>
      </div>
      <!-- Scheme Summary -->
      <div class="card" style="background: white; border: 1px solid var(--card-border); border-radius: 12px; padding: 20px; display: flex; align-items: center; gap: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
        <div style="width: 50px; height: 50px; border-radius: 50%; background: #F3E5F5; color: #7B1FA2; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
          <i class="fas fa-hand-holding-heart"></i>
        </div>
        <div>
          <h3 style="margin: 0; font-size: 1.4rem; color: #263238;"><%= recommendedSchemes ? recommendedSchemes.length : 0 %></h3>
          <p style="margin: 0; font-size: 0.85rem; color: #78909C;">Eligible Schemes Matched</p>
        </div>
      </div>
    </div>

    <!-- 3. Property Details (Including Demographics Profile) -->
    <div class="dashboard-card" id="propertyDetailsSection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-landmark"></i> Property & Profile Details</h3>
      </div>
      <div class="details-grid">
        <!-- Property Details Card -->
        <div class="details-group">
          <div class="details-group-title"><i class="fas fa-building"></i> Registered Property info</div>
          <% if (property) { %>
            <div class="profile-item"><i class="fas fa-id-card"></i> <strong>Property ID:</strong> <%= property.property_id %></div>
            <div class="profile-item"><i class="fas fa-home"></i> <strong>Property Type:</strong> <%= property.property_type %></div>
            <div class="profile-item"><i class="fas fa-ruler-combined"></i> <strong>Built-up Area:</strong> <%= property.built_up_area %> sq.ft.</div>
            <div class="profile-item"><i class="fas fa-map-marker-alt"></i> <strong>Address:</strong> <%= property.address %></div>
            <div class="profile-item"><i class="fas fa-calendar-alt"></i> <strong>Assessment Year:</strong> <%= property.assessment_year || '2025' %></div>
          <% } else { %>
            <p style="font-size: 0.85rem; color: #90A4AE; margin: 0;">No property details mapped to this citizen account.</p>
          <% } %>
        </div>
        <!-- Profile Demographics Card -->
        <div class="details-group">
          <div class="details-group-title"><i class="fas fa-user-circle"></i> Citizen Profile Demographics</div>
          <div class="profile-item"><i class="fas fa-user"></i> <strong>Full Name:</strong> <%= session.user.name %></div>
          <div class="profile-item"><i class="fas fa-phone"></i> <strong>Mobile Number:</strong> <%= session.user.phone %></div>
          <div class="profile-item"><i class="fas fa-fingerprint"></i> <strong>Aadhaar Number:</strong> <%= session.user.aadhaar || 'N/A' %></div>
          <div class="profile-item"><i class="fas fa-calendar-day"></i> <strong>Age & Gender:</strong> <%= session.user.age %> Years (<%= session.user.gender %>)</div>
          <div class="profile-item"><i class="fas fa-briefcase"></i> <strong>Occupation:</strong> <%= session.user.occupation || 'N/A' %></div>
        </div>
        <!-- Status & Farm Details Card -->
        <div class="details-group">
          <div class="details-group-title"><i class="fas fa-info-circle"></i> Social & Financial Profile</div>
          <div class="profile-item"><i class="fas fa-wallet"></i> <strong>Income Bracket:</strong> ₹<%= (session.user.income || 0).toLocaleString('en-IN') %>/year</div>
          <div class="profile-item"><i class="fas fa-seedling"></i> <strong>Farmer Status:</strong> <%= session.user.is_farmer ? 'Registered Farmer' : 'Non-Farmer' %> (<%= session.user.land_size %> Hectares)</div>
          <div class="profile-item"><i class="fas fa-wheelchair"></i> <strong>Special Ability:</strong> <%= session.user.disability ? 'Divyangjan' : 'General' %></div>
          <div class="profile-item"><i class="fas fa-user-graduate"></i> <strong>Student Status:</strong> <%= session.user.is_student ? 'Registered Student' : 'Non-Student' %></div>
        </div>
      </div>
    </div>

    <!-- 4. Tax Details Section -->
    <div class="dashboard-card" id="taxDetailsSection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-receipt"></i> Current Outstanding Tax Details</h3>
      </div>
      <% 
        const pendingBills = taxRecords.filter(r => r.status !== 'Paid');
      %>
      <% if (pendingBills.length === 0) { %>
        <div style="text-align: center; padding: 20px; color: #2E7D32;">
          <i class="fas fa-check-circle fa-2x mb-2"></i>
          <p style="margin: 0; font-weight: 600;">All property tax bills are fully paid. No outstanding taxes due.</p>
        </div>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 15px;">
          <% pendingBills.forEach(record => { %>
            <div style="border: 1px solid #ECEFF1; border-radius: 8px; padding: 20px; background: #FAF9F6; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
              <div>
                <h4 style="margin: 0 0 5px 0; color: var(--gov-primary); font-size: 1.1rem;">Property Tax Bill (Year: <%= record.year %>)</h4>
                <div style="font-size: 0.85rem; color: #546E7A; display: flex; gap: 15px; flex-wrap: wrap; margin-top: 8px;">
                  <span><strong>Tax Amount:</strong> ₹<%= record.tax_amount.toLocaleString('en-IN') %></span>
                  <span><strong>Due Date:</strong> <%= new Date(record.due_date).toLocaleDateString('en-IN') %></span>
                  <span><strong>Predicted Risk:</strong> 
                    <% const displayRisk = record.override_status || record.predicted_status || 'No Risk'; %>
                    <span class="status-badge <%= displayRisk === 'High Risk' ? 'overdue' : 'unpaid' %>" style="font-size: 0.75rem; padding: 2px 6px; border-radius: 4px;">
                      <%= displayRisk %>
                    </span>
                  </span>
                </div>
              </div>
              <div>
                <button class="btn btn-primary" onclick="openOfflinePaymentModal('<%= record.property_id %>', '<%= record.id %>', <%= record.tax_amount %>)" style="background: var(--gov-primary); border-color: var(--gov-primary); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; color: white;">
                  <i class="fas fa-calendar-check"></i> Book Offline Payment
                </button>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- 5. Scheme Eligibility Section (Now positioned near main dashboard cards) -->
    <div class="dashboard-card" id="schemeEligibilitySection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-hand-holding-heart"></i> Matching Government Welfare Schemes</h3>
        <span class="status-badge active" style="font-size: 0.75rem; padding: 2px 8px;">AI Live Match</span>
      </div>
      <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 20px; line-height: 1.5;">Our production Machine Learning models match your profile against state welfare benefits to suggest eligible schemes.</p>
      
      <% if (recommendedSchemes && recommendedSchemes.length > 0) { %>
        <div style="display: grid; grid-template-columns: 1fr; gap: 15px;">
          <% const rec = recommendedSchemes[0]; %>
          <div style="padding: 15px; border: 1px solid #ECEFF1; border-radius: 8px; background: #FAF9F6; border-left: 4px solid var(--gov-primary); display: flex; flex-direction: column; justify-content: space-between;">
            <div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 8px;">
                <h4 style="margin: 0; color: var(--gov-primary); font-weight: 600; font-size: 1rem;"><%= rec.scheme %></h4>
                <span class="status-badge active" style="font-size: 0.8rem; background: #E8F5E9; color: #2E7D32; font-weight: 600; padding: 2px 8px; border-radius: 4px;">
                  Score: <%= Math.round(rec.confidence * 100) %>%
                </span>
              </div>
              <ul style="margin: 0; padding-left: 20px; font-size: 0.85rem; color: #546E7A; line-height: 1.5;">
                <% rec.reasons.forEach(r => { %>
                  <li><%= r %></li>
                <% }); %>
              </ul>
            </div>
          </div>
        </div>
      <% } else { %>
        <div style="text-align: center; padding: 30px; color: #546E7A; background: #FAF9F6; border-radius: 8px; border: 1px solid #ECEFF1; border-left: 4px solid #B0BEC5;">
          <i class="fas fa-info-circle fa-2x mb-2" style="color: #B0BEC5;"></i>
          <p style="margin: 0; font-size: 0.95rem; font-weight: 600;">No Government Welfare Scheme matches your current profile.</p>
        </div>
      <% } %>
    </div>

    <!-- 6. Complaint Registration Section -->
    <div class="dashboard-card" id="complaintRegistrationSection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-pen-alt"></i> Lodge a Grievance</h3>
      </div>
      <form id="complaintForm">
        <div class="form-group" style="margin-bottom: 15px;">
          <label class="form-label" for="complaintDesc" style="font-weight: 600; display: block; margin-bottom: 5px; color: #37474F;">Describe your grievance:</label>
          <textarea id="complaintDesc" class="form-control" rows="4" placeholder="Describe the issue in detail (e.g. Street light on main road Block B is sparking, open manhole blocking the main drain...)" required style="width: 100%; padding: 10px; border: 1px solid #CCC; border-radius: 6px; box-sizing: border-box; resize: vertical;"></textarea>
          <div style="background-color: #FFF9C4; color: #F57F17; border-left: 3px solid #FBC02D; padding: 8px 12px; border-radius: 4px; font-size: 0.8rem; margin-top: 8px; font-family: inherit; line-height: 1.4; margin-bottom: 4px;">
            <strong>Tip:</strong> Clearly describe emergency situations (for example, tree fallen, fire, electric wire, gas leak, road blocked) so the system can prioritize urgent complaints correctly.
          </div>
          <small class="text-muted" style="font-size: 0.75rem; color: #78909C; display: block; margin-top: 4px;"><i class="fas fa-info-circle"></i> Minimum 10 characters required. Priority predicted dynamically.</small>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
          <div class="form-group">
            <label class="form-label" for="complaintCategory" style="font-weight: 600; display: block; margin-bottom: 5px; color: #37474F;">Category:</label>
            <select id="complaintCategory" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 6px; height: 38px;">
              <option value="">-- Choose Category --</option>
              <option value="Water Supply">Water Supply</option>
              <option value="Road Damage">Road Damage</option>
              <option value="Street Light">Street Light</option>
              <option value="Sanitation">Sanitation</option>
              <option value="Drainage">Drainage</option>
              <option value="Electricity">Electricity</option>
              <option value="Others">Others</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="complaintWard" style="font-weight: 600; display: block; margin-bottom: 5px; color: #37474F;">Ward Number:</label>
            <select id="complaintWard" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 6px; height: 38px;">
              <option value="Ward 1">Ward 1</option>
              <option value="Ward 2">Ward 2</option>
              <option value="Ward 3">Ward 3</option>
              <option value="Ward 4">Ward 4</option>
            </select>
          </div>
        </div>

        <button type="submit" id="submitComplaintBtn" class="btn btn-primary" style="width: 100%; background: var(--gov-primary); border-color: var(--gov-primary); color: white; padding: 12px; font-weight: 600; font-size: 1rem; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; border: none;">
          <i class="fas fa-paper-plane"></i> File Complaint
        </button>
      </form>
    </div>

    <!-- 7. Complaint History Section -->
    <div class="dashboard-card" id="complaintHistorySection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-history"></i> Complaint History</h3>
      </div>
      <div class="table-responsive" style="overflow-x: auto; width: 100%;">
        <table class="table" style="font-size: 0.85rem; width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid var(--card-border); background-color: #F8F9FA;">
              <th style="padding: 12px 10px; text-align: left; font-weight: 600; color: #37474F;">Complaint ID</th>
              <th style="padding: 12px 10px; text-align: left; font-weight: 600; color: #37474F;">Complaint Description</th>
              <th style="padding: 12px 10px; text-align: left; font-weight: 600; color: #37474F;">Ward Number</th>
              <th style="padding: 12px 10px; text-align: left; font-weight: 600; color: #37474F;">Priority</th>
              <th style="padding: 12px 10px; text-align: left; font-weight: 600; color: #37474F;">Status</th>
              <th style="padding: 12px 10px; text-align: left; font-weight: 600; color: #37474F;">Date Submitted</th>
            </tr>
          </thead>
          <tbody>
            <% if (complaints.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">No complaints found.</td>
              </tr>
            <% } else { %>
              <% complaints.forEach(c => { %>
                <tr style="border-bottom: 1px solid var(--card-border); <%= c.is_duplicate ? 'opacity: 0.8;' : '' %>">
                  <td style="padding: 12px 10px;"><strong>#<%= c.id %></strong></td>
                  <td style="padding: 12px 10px; max-width: 220px; word-wrap: break-word; line-height: 1.4;">
                    <div style="font-weight: 500; color: #263238;"><%= c.description %></div>
                    <div style="font-size: 0.75rem; color: #78909C; margin-top: 2px;"><%= c.category %></div>
                    <% if (c.admin_remarks) { %>
                      <div style="font-size: 0.75rem; color: var(--gov-secondary); margin-top: 4px; font-weight: 600;"><i class="fas fa-comment-dots"></i> Remarks: <%= c.admin_remarks %></div>
                    <% } %>
                  </td>
                  <td style="padding: 12px 10px;"><%= c.ward %></td>
                  <td style="padding: 12px 10px;">
                    <span class="status-badge <%= c.priority === 'High' ? 'overdue' : c.priority === 'Medium' ? 'unpaid' : 'paid' %>" style="font-size: 0.75rem; padding: 2px 6px; border-radius: 4px;">
                      <%= c.priority %>
                    </span>
                  </td>
                  <td style="padding: 12px 10px;">
                    <span class="status-badge <%= c.status === 'Resolved' ? 'paid' : c.status === 'In Progress' ? 'unpaid' : 'inactive' %>" style="font-size: 0.75rem; padding: 2px 6px; border-radius: 4px;">
                      <%= c.status %>
                    </span>
                  </td>
                  <td style="padding: 12px 10px;"><%= new Date(c.created_at).toLocaleDateString('en-IN') %></td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 8. Tax History Section -->
    <div class="dashboard-card" id="taxHistorySection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-receipt"></i> Property Tax History</h3>
      </div>
      <div class="table-responsive" style="overflow-x: auto; width: 100%;">
        <table class="table" style="font-size: 0.9rem; width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid var(--card-border); background-color: #F8F9FA;">
              <th style="padding: 12px 10px; text-align: left;">Year</th>
              <th style="padding: 12px 10px; text-align: left;">Tax Amount</th>
              <th style="padding: 12px 10px; text-align: left;">Due Date</th>
              <th style="padding: 12px 10px; text-align: left;">Default Risk</th>
              <th style="padding: 12px 10px; text-align: left;">Status</th>
              <th style="padding: 12px 10px; text-align: left;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (taxRecords.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">No tax bills found</td>
              </tr>
            <% } else { %>
              <% taxRecords.forEach(record => { %>
                <tr style="border-bottom: 1px solid var(--card-border);">
                  <td style="padding: 12px 10px;"><strong><%= record.year %></strong></td>
                  <td style="padding: 12px 10px;"><strong>₹<%= record.tax_amount.toLocaleString('en-IN') %></strong></td>
                  <td style="padding: 12px 10px;"><%= new Date(record.due_date).toLocaleDateString('en-IN') %></td>
                  <td style="padding: 12px 10px;">
                    <% const displayRisk = record.override_status || record.predicted_status || 'No Risk'; %>
                    <span class="status-badge <%= displayRisk === 'High Risk' ? 'overdue' : (displayRisk === 'Medium Risk' || displayRisk === 'Low Risk') ? 'unpaid' : 'paid' %>" style="font-size: 0.75rem; padding: 3px 8px; border-radius: 4px;">
                      <%= displayRisk %>
                    </span>
                  </td>
                  <td style="padding: 12px 10px;">
                    <span class="status-badge <%= record.status.toLowerCase() %>" style="font-size: 0.75rem; padding: 3px 8px; border-radius: 4px;"><%= record.status %></span>
                  </td>
                  <td style="padding: 12px 10px;">
                    <% if (record.status === 'Unpaid' || record.status === 'Pending' || record.status === 'Overdue') { %>
                      <button class="btn btn-primary btn-sm" onclick="openOfflinePaymentModal('<%= record.property_id %>', '<%= record.id %>', <%= record.tax_amount %>)" style="background: var(--gov-primary); border-color: var(--gov-primary); display: inline-flex; align-items: center; gap: 5px; cursor: pointer; border-radius: 4px; padding: 5px 10px; font-size: 0.8rem; color: white;">
                        <i class="fas fa-calendar-check"></i> Pay Offline
                      </button>
                    <% } else { %>
                      <span class="text-success" style="font-weight: 600;"><i class="fas fa-check-circle"></i> Clear</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 9. Notifications Section -->
    <div class="dashboard-card" id="notificationsSection">
      <div class="card-header-custom">
        <h3 class="card-title-custom"><i class="fas fa-bell"></i> Alerts & Notifications</h3>
      </div>
      <div style="max-height: 320px; overflow-y: auto; padding-right: 5px;">
        <% if (notifications && notifications.length > 0) { %>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <% notifications.forEach(function(n) { %>
              <div class="notif-item" data-id="<%= n.id %>" style="padding: 12px; border-radius: 8px; background: #F9F9F9; border-left: 4px solid var(--gov-secondary); position: relative; border: 1px solid #ECEFF1; border-left-width: 4px;">
                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; font-weight: 600; margin-bottom: 4px; color: #37474F;">
                  <span><%= n.title %></span>
                  <small class="text-muted" style="margin-right: 15px;"><%= new Date(n.created_at).toLocaleDateString('en-IN') %></small>
                </div>
                <p style="font-size: 0.8rem; margin: 0; color: #546E7A; line-height: 1.4;"><%= n.message %></p>
                <button class="notif-dismiss" onclick="dismissNotif('<%= n.id %>', this)" style="position: absolute; top: 8px; right: 8px; background: none; border: none; cursor: pointer; color: #90A4AE; font-size: 1.1rem; line-height: 1;">&times;</button>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div style="text-align: center; padding: 20px; color: #90A4AE; font-size: 0.9rem;">
            <i class="fas fa-bell-slash fa-2x mb-2" style="color: #CFD8DC;"></i><br>
            No active notifications at this time.
          </div>
        <% } %>
      </div>
    </div>

  </main>

  <!-- Offline Payment Booking Modal -->
  <div id="offlinePaymentModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="modal-content" style="background: white; padding: 25px; border-radius: 12px; max-width: 450px; width: 90%; box-shadow: 0 5px 15px rgba(0,0,0,0.2); position: relative;">
      <button class="modal-close" onclick="closeOfflinePaymentModal()" style="position: absolute; top: 15px; right: 15px; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #888;">&times;</button>
      <h3 style="margin-bottom: 20px; color: var(--gov-primary);"><i class="fas fa-calendar-check"></i> Book Offline Payment</h3>
      
      <form id="offlinePaymentForm" onsubmit="submitOfflinePayment(event)">
        <input type="hidden" id="offlineTaxRecordId">
        
        <div class="form-group" style="margin-bottom: 15px;">
          <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 5px;">Property ID</label>
          <input type="text" id="offlinePropertyId" class="form-control" readonly style="background: #F5F5F5; width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 6px; box-sizing: border-box;">
        </div>
        
        <div class="form-group" style="margin-bottom: 15px;">
          <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 5px;">Tax Amount</label>
          <input type="text" id="offlineTaxAmountDisplay" class="form-control" readonly style="background: #F5F5F5; width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 6px; box-sizing: border-box;">
          <input type="hidden" id="offlineTaxAmount">
        </div>
        
        <div class="form-group" style="margin-bottom: 15px;">
          <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 5px;">Appointment Date</label>
          <input type="date" id="offlineAppDate" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 6px; box-sizing: border-box;" min="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        
        <div class="form-group" style="margin-bottom: 20px;">
          <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 5px;">Appointment Time</label>
          <input type="time" id="offlineAppTime" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #CCC; border-radius: 6px; box-sizing: border-box;">
        </div>
        
        <div style="display: flex; justify-content: flex-end; gap: 10px;">
          <button type="button" class="btn btn-outline" onclick="closeOfflinePaymentModal()" style="border: 1px solid #CCC; padding: 8px 16px; border-radius: 6px; cursor: pointer; background: transparent;">Cancel</button>
          <button type="submit" class="btn btn-primary" style="background: var(--gov-primary); border-color: var(--gov-primary); color: white; padding: 8px 16px; border-radius: 6px; cursor: pointer; border: none; font-weight: 600;">Book Appointment</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/main.js?v=<%= Date.now() %>"></script>
  <!-- Include chatbot -->
  <%- include('partials/chatbot') %>

  <!-- Dashboard Logics -->
  <script>
    // Dismiss citizen notifications
    function dismissNotif(id, btn) {
      const item = btn.closest('.notif-item');
      fetch('/api/notifications/dismiss', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          item.remove();
        }
      });
    }

    // Book appointment modal actions
    function openOfflinePaymentModal(propertyId, taxRecordId, amount) {
      document.getElementById('offlinePropertyId').value = propertyId;
      document.getElementById('offlineTaxRecordId').value = taxRecordId;
      document.getElementById('offlineTaxAmount').value = amount;
      document.getElementById('offlineTaxAmountDisplay').value = '₹' + amount.toLocaleString('en-IN');
      
      const modal = document.getElementById('offlinePaymentModal');
      modal.style.display = 'flex';
    }

    function closeOfflinePaymentModal() {
      const modal = document.getElementById('offlinePaymentModal');
      modal.style.display = 'none';
    }

    function submitOfflinePayment(event) {
      event.preventDefault();
      const propertyId = document.getElementById('offlinePropertyId').value;
      const taxRecordId = document.getElementById('offlineTaxRecordId').value;
      const amount = document.getElementById('offlineTaxAmount').value;
      const appointmentDate = document.getElementById('offlineAppDate').value;
      const appointmentTime = document.getElementById('offlineAppTime').value;
      
      const submitBtn = event.target.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Booking...';
      
      fetch('/api/book-offline-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          propertyId,
          taxRecordId,
          amount: parseFloat(amount),
          appointmentDate,
          appointmentTime
        })
      })
      .then(res => res.json())
      .then(data => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Book Appointment';
        if (data.success) {
          alert('Offline appointment booked successfully! Check details in your portal feed.');
          closeOfflinePaymentModal();
          window.location.reload();
        } else {
          alert('Booking failed: ' + data.error);
        }
      })
      .catch(err => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Book Appointment';
        alert('Error booking appointment: ' + err.message);
      });
    }

    // Complaint submission form
    const complaintForm = document.getElementById("complaintForm");
    const descArea = document.getElementById("complaintDesc");
    const catSelect = document.getElementById("complaintCategory");

    complaintForm.addEventListener("submit", (e) => {
      e.preventDefault();
      
      const desc = descArea.value.trim();
      const cat = catSelect.value;
      const ward = document.getElementById("complaintWard").value;

      if (desc.length < 10) {
        alert("Please enter at least 10 characters describing the issue.");
        return;
      }

      const submitBtn = document.getElementById("submitComplaintBtn");
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Registering...';

      fetch('/api/complaints', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ description: desc, category: cat, ward: ward })
      })
      .then(res => res.json())
      .then(data => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> File Complaint';
        if (data.success) {
          alert(data.message);
          window.location.reload();
        } else {
          alert("Error filing complaint: " + data.error);
        }
      })
      .catch(err => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> File Complaint';
        alert("Network error submission failed: " + err.message);
      });
    });
  </script>
</body>
</html>
